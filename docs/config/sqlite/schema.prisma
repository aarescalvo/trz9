  camaraOrigen    Camara?  @relation("CamaraOrigen", fields: [camaraOrigenId], references: [id])
  camaraDestinoId String?
  camaraDestino   Camara?  @relation("CamaraDestino", fields: [camaraDestinoId], references: [id])
  
