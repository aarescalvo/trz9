  fechaIngreso      DateTime         @default(now())
  fechaElaboracion  DateTime?
  
  // Rótulo
  rotuloImpreso     Boolean          @default(false)
  
  observaciones     String?
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  @@index([tropaCodigo])
  @@index([fechaIngreso])
