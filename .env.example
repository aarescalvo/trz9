# SOLEMAR ALIMENTARIA - Configuracion de base de datos
#
# Copiar este archivo como .env y ajustar los valores:
#   copy .env.example .env
#
# Para PRODUCCION (PostgreSQL) - USAR ESTA CONFIGURACION:
DATABASE_URL="postgresql://postgres:1810@localhost:5432/trz5?schema=public"
#
# Para DESARROLLO local (SQLite) - NO usar en produccion:
# DATABASE_URL="file:./db/custom.db"
