  fechaHasta      DateTime?
  activo          Boolean       @default(true)
  
  // Observaciones
  observaciones   String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([clienteId])
  @@index([productoId])
  @@index([fechaDesde])
  @@index([activo])
