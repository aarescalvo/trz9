  updatedAt       DateTime      @updatedAt
}

// ==================== RENDERING (Subproductos) ====================

model RegistroRendering {
  id              String            @id @default(cuid())
  tipo            TipoRendering
  
  // Datos de origen
  fechaFaena      DateTime          @default(now())
  tropaId         String?
  tropa           Tropa?            @relation(fields: [tropaId], references: [id])
  
  // Peso
  pesoKg          Float
  
  // Destino
  destino         String?           // Cliente/Proveedor
  despachado      Boolean           @default(false)
  fechaDespacho   DateTime?
  
  // Observaciones
  observaciones   String?
  
  // Operador
  operadorId      String?
  operador        Operador?         @relation(fields: [operadorId], references: [id])
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([tipo])
  @@index([fechaFaena])
  @@index([despachado])
}

enum TipoRendering {
  GRASA
  DESPERDICIOS
  FONDO_DIGESTOR
  SANGRE
}

// ==================== CUEROS ====================

model RegistroCuero {
  id              String            @id @default(cuid())
  
  // Datos de origen
  fechaFaena      DateTime          @default(now())
  tropaId         String?
  tropa           Tropa?            @relation(fields: [tropaId], references: [id])
  
  // Categoría
  categoria       CategoriaCuero
  
  // Peso (al momento del registro inicial)
  pesoKg          Float?
  
  // Cantidad de cueros
  cantidad        Int               @default(1)
  
  // Despacho
  destino         String?           // Curtiembre, venta directa
  tipoDestino     TipoDestinoCuero?
  despachado      Boolean           @default(false)
  fechaDespacho   DateTime?
  pesoDespacho    Float?            // Peso real al despacho
  remito          String?           // Número de remito
  
  // Observaciones
  observaciones   String?
  
  // Operador
  operadorId      String?
  operador        Operador?         @relation(fields: [operadorId], references: [id])
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([categoria])
  @@index([fechaFaena])
  @@index([despachado])
}

enum CategoriaCuero {
  SALADO
  FRESCO
  CORTADO
}

enum TipoDestinoCuero {
  CURTIEMBRE
  VENTA_DIRECTA
}

// ==================== MOVIMIENTOS DESPOSTADA ====================

model MovimientoDespostada {
  id              String            @id @default(cuid())
  
  // Lote
  loteId          String
  lote            LoteDespostada    @relation(fields: [loteId], references: [id])
  
  // Producto/Corte
  productoId      String?
  producto        Producto?         @relation(fields: [productoId], references: [id])
  nombreCorte     String?           // Nombre manual si no hay producto
  
  // Pesos
  pesoOriginal    Float             // Peso antes de limpieza
  pesoLimpio      Float?            // Peso después de limpieza
  pesoDesperdicio Float?            // Diferencia = merma
  
  // Destino del corte
  destino         DestinoCorte?
  
  // Tipo de registro
  tipo            TipoMovimientoDespostada
  
  // Causa/Motivo (para desperdicios)
  causa           String?
  
  // Huesos y grasas (registro adicional)
  esHueso         Boolean           @default(false)
  esGrasa         Boolean           @default(false)
  
  // Operador
  operadorId      String?
  operador        Operador?         @relation(fields: [operadorId], references: [id])
  
  observaciones   String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([loteId])
  @@index([tipo])
  @@index([createdAt])
}

