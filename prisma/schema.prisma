  productor             Cliente?            @relation(fields: [productorId], references: [id])
  nombreProductor       String              // Nombre del productor (denormalizado)
  cuitProductor         String?             // CUIT del productor
  direccionProductor    String?             // Dirección del productor
  
  // Datos del origen
  procedencia           String?             // Lugar de procedencia de los animales
  
  // Datos de la especie
  especie               Especie             @default(BOVINO)
  
  // Cantidad
  cantidadCabezas       Int                 // Cantidad de animales
  
  // Identificación de tropa/lote
  numeroTropa          String?             // Número de tropa
  numeroLote           String?             // Número de lote
  
  // Documentos de origen
  numeroDTE            String?             // Documento de Tránsito Electrónico
  numeroGuia           String?             // Guía de tránsito
  
  // Declaración de sanidad
  declaracionSanidad   String?             // Texto de la declaración
  procedenciaLibre     Boolean             @default(true)  // Si proviene de zona libre
  
  // Observaciones
