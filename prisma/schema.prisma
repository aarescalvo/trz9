  vecesImpreso          Int           @default(0)
  
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  @@index([fechaEmision])
  @@index([estado])
  @@index([paisDestino])
}

enum EstadoCCIR {
  EMITIDO
  ANULADO
  EXPORTADO
}

// ==================== DECLARACIÓN JURADA ====================

model DeclaracionJurada {
