  activo        Boolean @default(true)
  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo])
}

// ==================== CALIDAD - RECLAMOS DE CLIENTES ====================

model ReclamoCliente {
  id String @id @default(cuid())

  // Cliente relacionado (usuario de faena)
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  // Tipo de reclamo
  tipo TipoReclamo

  // Datos del reclamo
  titulo      String
  descripcion String? // Detalle del reclamo/queja

  // Fecha del evento
  fecha DateTime @default(now())

  // Tropa/animal relacionado (opcional)
  tropaCodigo String? // Si está relacionado con una tropa específica

  // Responsable que registra
  registradoPor String? // Nombre del operador que registra

  // Estado
  estado    EstadoReclamo    @default(PENDIENTE)
  prioridad PrioridadReclamo @default(NORMAL)

  // Respuesta/Resolución
  respuesta      String? // Respuesta dada al cliente
  fechaRespuesta DateTime? // Cuándo se respondió
  respondidoPor  String? // Quién dio la respuesta

  // Resolución
  fechaResolucion DateTime? // Cuándo se resolvió definitivamente
  resueltoPor     String? // Quién resolvió
  resultado       String? // Resultado final (favorable, desestimado, etc.)

  // Seguimiento
  seguimiento String? // Notas internas de seguimiento

  // Adjuntos (URLs)
  adjuntoUrl String?

  // Observaciones
  observaciones String?

  // Auditoría
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clienteId])
  @@index([tipo])
  @@index([estado])
  @@index([fecha])
  @@index([prioridad])
}

enum TipoReclamo {
  RECLAMO // Reclamo formal
  QUEJA // Queja sobre servicio
  INCIDENTE // Incidente durante la faena
  CONSULTA // Consulta o solicitud
  SUGERENCIA // Sugerencia de mejora
  OTRO // Otro tipo
}

// ==================== RÓTULOS / ETIQUETAS ====================

model Rotulo {
  id     String @id @default(cuid())
  nombre String // Nombre del rótulo
  codigo String @unique // Código interno (MEDIA_RES, CUARTO, etc.)

  // Tipo y categoría
  tipo      TipoRotulo
  categoria String? // ENVASE_PRIMARIO, ENVASE_SECUNDARIO, etc.

  // Tipo de impresora: ZEBRA (ZPL) o DATAMAX (DPL)
  tipoImpresora   String  @default("ZEBRA") // ZEBRA | DATAMAX
  modeloImpresora String? @default("ZT410") // ZT410, ZT230, MARK_II, etc.

  // Dimensiones en mm
  ancho Int @default(80)
  alto  Int @default(50)
  dpi   Int @default(203) // Resolución: 203, 300, 600

  // Contenido de la plantilla (raw del archivo)
  contenido     String // Contenido del archivo ZPL o DPL
  variables     String? // JSON con variables detectadas
  nombreArchivo String? // Nombre del archivo original
  esBinario     Boolean @default(false) // Archivo .lbl/.nlbl (Zebra Designer)

  // Configuración de consumo
  diasConsumo    Int?   @default(30) // Días para consumir
  temperaturaMax Float? @default(5.0)

  // Estado
  activo    Boolean @default(true)
  esDefault Boolean @default(false) // Si es el rótulo por defecto del tipo

  // Elementos para editor visual
  elementos RotuloElemento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo])
  @@index([activo])
  @@index([tipoImpresora])
}

enum EstadoReclamo {
  PENDIENTE // Pendiente de atención
  EN_REVISION // En revisión/análisis
  RESPONDIDO // Se dio respuesta al cliente
  RESUELTO // Resuelto definitivamente
  CERRADO // Cerrado sin resolución
  ANULADO // Anulado
}

enum PrioridadReclamo {
  BAJA // No urgente
  NORMAL // Prioridad normal
  ALTA // Requiere atención pronta
  URGENTE // Urgente, atención inmediata
}

// ==================== SISTEMA DE EMAILS ====================

model DestinatarioReporte {
  id     String  @id @default(cuid())
  nombre String // Nombre del destinatario
  email  String // Dirección de email
  activo Boolean @default(true) // Si está activo para recibir emails

  // Tipos de reportes que recibe
  recibeStock       Boolean @default(false) // Reportes de stock
  recibeFaena       Boolean @default(false) // Reportes de faena diaria
  recibeRendimiento Boolean @default(false) // Reportes de rendimiento
  recibeAlertas     Boolean @default(false) // Alertas del sistema

  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  historialesEnvio HistorialEnvio[]

  @@index([email])
  @@index([activo])
}

model ProgramacionReporte {
  id     String @id @default(cuid())
  nombre String // Nombre de la programación

  // Tipo de reporte
  tipoReporte TipoReporteEmail

  // Configuración de envío
  frecuencia FrecuenciaEmail
  horaEnvio  Int             @default(8) // Hora del día (0-23)
  diaSemana  Int? // Día de la semana (0=Domingo, 6=Sábado) para semanal
  diaMes     Int? // Día del mes (1-31) para mensual

  // Destinatarios (lista de IDs separados por coma o JSON)
  destinatarios String // IDs de DestinatarioReporte separados por coma

  // Estado
  activo       Boolean   @default(true)
  ultimoEnvio  DateTime?
  proximoEnvio DateTime?

  // Configuración adicional
  incluirGraficos Boolean        @default(true)
  formato         FormatoReporte @default(PDF)

  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  historialesEnvio HistorialEnvio[]

  @@index([tipoReporte])
  @@index([activo])
  @@index([proximoEnvio])
}

model HistorialEnvio {
  id String @id @default(cuid())

  // Referencias
  programacionId String?
  programacion   ProgramacionReporte? @relation(fields: [programacionId], references: [id])
  destinatarioId String?
  destinatario   DestinatarioReporte? @relation(fields: [destinatarioId], references: [id])

  // Datos del envío
  tipoReporte       TipoReporteEmail
  asunto            String
  destinatarioEmail String // Email del destinatario (denormalizado)

  // Estado del envío
  estado         EstadoEnvioEmail @default(PENDIENTE)
  fechaEnvio     DateTime         @default(now())
  fechaProcesado DateTime?

  // Información adicional
  error         String? // Mensaje de error si falló
  reintentos    Int     @default(0)
  tamanoArchivo Int? // Tamaño del archivo adjunto en bytes

  // Contenido
  contenidoResumen String? // Resumen del contenido enviado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipoReporte])
  @@index([estado])
  @@index([fechaEnvio])
  @@index([destinatarioEmail])
}

enum TipoReporteEmail {
  STOCK_DIARIO // Reporte de stock diario
  STOCK_SEMANAL // Reporte de stock semanal
  FAENA_DIARIO // Reporte de faena diario
  FAENA_SEMANAL // Reporte de faena semanal
  RENDIMIENTO_DIARIO // Reporte de rendimiento diario
  RENDIMIENTO_SEMANAL // Reporte de rendimiento semanal
  ALERTA_STOCK_BAJO // Alerta de stock bajo
  ALERTA_CAMARA // Alerta de capacidad de cámara
  RESUMEN_MENSUAL // Resumen mensual completo
  PERSONALIZADO // Reporte personalizado
}

enum FrecuenciaEmail {
  DIARIO // Todos los días
  SEMANAL // Una vez por semana
  QUINCENAL // Cada 15 días
  MENSUAL // Una vez por mes
  MANUAL // Solo envío manual
}

enum EstadoEnvioEmail {
  PENDIENTE // Pendiente de envío
  ENVIANDO // En proceso de envío
  ENVIADO // Enviado exitosamente
  ERROR // Error en el envío
  REINTENTO // Pendiente de reintento
}

enum FormatoReporte {
  PDF // Formato PDF
  EXCEL // Formato Excel
  AMBOS // Ambos formatos
}

// ==================== LAYOUT GLOBAL DE MÓDULOS ====================
model LayoutGlobalModulo {
  id     String @id @default(cuid())
  modulo String @unique // "ingresoCajon", "romaneo", "pesajeIndividual", etc.

  // Layout WYSIWYG con posiciones exactas
  layout String? // JSON con posiciones X, Y, width, height:
  // { "items": [{ "id": "header", "x": 20, "y": 20, "width": 900, "height": 70, "texto": "Título" }] }

  // Configuración de bloques (formato antiguo, compatibilidad)
  bloques String? // JSON con configuración de cada bloque

  // Configuración de botones
  botones String? // JSON con textos y visibilidad de botones:
  // { "items": [{ "id": "asignar", "texto": "ASIGNAR GARRÓN", "visible": true }] }

  // Configuración visual
  tema           String? // "default", "compacto", "amplio"
  colorPrincipal String? // Color principal del módulo

  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([modulo])
}

// ==================== DESPACHOS / EXPEDICIÓN ====================

model Despacho {
  id     String   @id @default(cuid())
  numero Int      @unique // Número correlativo de despacho
  fecha  DateTime @default(now())

  // Destino
  destino          String // Destino del despacho
  direccionDestino String? // Dirección de entrega

  // Datos del camión
  patenteCamion   String? // Patente del camión
  patenteAcoplado String? // Patente del acoplado
  chofer          String? // Nombre del chofer
  choferDni       String? // DNI del chofer
  patenteChasis   String? // Patente del chasis (alternativa)
  choferNombre    String? // Nombre del chofer (alternativa)
  transportista   String? // Nombre del transportista
  transportistaId String? // ID del transportista (si está registrado)

  // Cliente
  clienteId String?
  cliente   Cliente? @relation("DespachoCliente", fields: [clienteId], references: [id])

  // Documentos
  remito          String? // Número de remito
  numeroPrecintos String? // Números de precintos separados por coma

  // Pesos
  kgTotal        Float @default(0) // Total de KG despachados
  cantidadMedias Int   @default(0) // Total de medias reses

  // Ticket de pesaje (salida con mercadería)
  ticketPesajeId String? // ID del pesaje de camión de salida
  ticketPesaje   PesajeCamion? @relation(fields: [ticketPesajeId], references: [id])

  // Pesaje de salida (asociado al pesaje de camión de salida)
  pesajeCamionId String?       @unique
  pesajeCamion   PesajeCamion? @relation("DespachoPesajeCamion", fields: [pesajeCamionId], references: [id])

  // Estado
  estado EstadoDespacho @default(PENDIENTE)

  // Observaciones
  observaciones String?

  // Operador que registró
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      DespachoItem[]
  lineas     DespachoItem[] @relation("DespachoLineas")
  ordenCarga OrdenCarga?

  // Facturación
  facturado        Boolean   @default(false) // Si ya fue facturado (todas las medias)
  fechaFacturacion DateTime? // Fecha en que se generó la factura
  facturas         Factura[] // Facturas generadas desde este despacho
  facturaId        String? // ID de la última factura asociada
  fechaDespacho    DateTime? // Fecha de despacho efectivo

  @@index([fecha])
  @@index([estado])
  @@index([destino])
  @@index([clienteId])
}

model DespachoItem {
  id              String    @id @default(cuid())
  despachoId      String
  despacho        Despacho  @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  despachoLineaId String?
  despachoLinea   Despacho? @relation("DespachoLineas", fields: [despachoLineaId], references: [id])

  // Media res despachada
  mediaResId String
  mediaRes   MediaRes @relation(fields: [mediaResId], references: [id])

  // Datos denormalizados para reportes
  tropaCodigo String? // Código de tropa
  garron      Int? // Número de garrón
  peso        Float // Peso de la media res
  camaraId    String? // Cámara de origen (para restaurar al anular)

  // Usuario (cliente) al que pertenece
  usuarioId     String? // ID del usuario de faena
  usuarioNombre String? // Nombre del usuario (denormalizado)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([despachoId])
  @@index([tropaCodigo])
  @@index([usuarioId])
  @@index([camaraId])
}

enum EstadoDespacho {
  PENDIENTE // En preparación
  EN_CARGA // Cargando en camión
  DESPACHADO // Despachado
  ENTREGADO // Entregado en destino
  ANULADO // Anulado
}

// ==================== CUEROS ====================

