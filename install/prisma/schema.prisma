  datosReporte String? // Resumen de datos incluidos

  // Observaciones
  observaciones String?

  // Operador que generó
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipoReporte])
  @@index([estado])
  @@index([fechaDesde])
  @@index([fechaEnvio])
