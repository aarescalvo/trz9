enum TipoReporteSenasa {
  FAENA_MENSUAL
  EXISTENCIAS
  MOVIMIENTOS
  DECOMISOS
  PRODUCCION
  STOCK
}

enum EstadoReporteSenasa {
  PENDIENTE
  ENVIADO
  CONFIRMADO
  ERROR
  ANULADO
}

// ==================== CONFIGURACIÓN CÓDIGO DE BARRAS ====================

model CodigoBarrasConfig {
