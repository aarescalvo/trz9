// ==================== ELEMENTOS DE RÓTULO (EDITOR VISUAL) ====================

model RotuloElemento {
  id       String @id @default(cuid())
  rotuloId String
  rotulo   Rotulo @relation(fields: [rotuloId], references: [id], onDelete: Cascade)

  // Tipo de elemento
  tipo String // TEXTO, CODIGO_BARRAS, LINEA, RECTANGULO, IMAGEN

  // Datos del campo (para TEXTO y CODIGO_BARRAS)
  campo     String? // Variable: numeroAnimal, peso, fecha, etc. (null = texto fijo)
  textoFijo String? // Texto estático si campo es null

  // Posición y tamaño (en puntos según DPI)
  posX  Int  @default(0) // Posición X en puntos
  posY  Int  @default(0) // Posición Y en puntos
  ancho Int? @default(100) // Ancho en puntos
  alto  Int? @default(30) // Alto en puntos

  // Fuente (para TEXTO)
  fuente      String? @default("0") // ZPL: 0-9, A-Z; DPL: nombre de fuente
  tamano      Int?    @default(10) // Tamaño de fuente
  negrita     Boolean @default(false)
  anchoFuente Int?    @default(0) // Ancho de carácter en puntos (ZPL)

  // Alineación
  alineacion String? @default("LEFT") // LEFT, CENTER, RIGHT

  // Código de barras
  tipoCodigo   String? @default("CODE128") // CODE128, CODE39, EAN13, etc.
  altoCodigo   Int?    @default(60) // Alto del código de barras
  mostrarTexto Boolean @default(true) // Mostrar texto debajo del código

  // Líneas y rectángulos
  grosorLinea Int?    @default(2) // Grosor en puntos
  color       String? @default("B") // B=Black, W=White

  // Orden (z-index)
  orden Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rotuloId])
  @@index([tipo])
}

// ==================== PLANTILLAS DE REPORTES ====================

model PlantillaReporte {
  id          String  @id @default(cuid())
  nombre      String  @unique // "Planilla Faena Diaria", "Reporte SENASA"
  codigo      String  @unique // "FAENA_DIARIA", "SENASA_MENSUAL"
  descripcion String?

  // Archivo de plantilla
  archivoNombre    String // Original filename
  archivoContenido String // Base64 encoded Excel file

  // Configuración de marcadores
  marcadores String? // JSON: {"A5": "{{FECHA}}", "B5": "{{TROPA}}"}
  hojaDatos  String? @default("Datos") // Nombre de la hoja donde van los datos
  filaInicio Int     @default(1) // Fila donde empiezan los datos

  // Rango de datos (para tablas)
  rangoDatos String? // "A7:F50" - donde se insertan filas
  columnas   String? // JSON: ["fecha", "tropa", "cabezas", "peso"]

  // Configuración de impresión
  orientacion String? @default("portrait") // portrait | landscape
  tamanoPapel String? @default("A4")

  // Estado
  activo    Boolean @default(true)
  categoria String? // FAENA, STOCK, DESPOSTADA, SENASA

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoria])
  @@index([activo])
}

// ==================== SERVICIOS Y PRECIOS ====================

model TipoServicio {
  id          String  @id @default(cuid())
  codigo      String  @unique // FAENA, EMBOLSADO_VACIO, DESHUESADO, etc.
  nombre      String // "Servicio de Faena x Kg"
  descripcion String?

  // Unidad de medida
  unidad String @default("KG") // KG, UN, HORA

  // Configuración
  seFactura  Boolean @default(true) // Si se factura o está incluido en otro servicio
  incluidoEn String? // Código del servicio que lo incluye (ej: "FAENA")

  // IVA por defecto
  porcentajeIva Float @default(21) // 10.5 o 21

  // Orden de aparición
  orden Int @default(0)

  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  precios         PrecioServicio[]
  detallesFactura DetalleFactura[]

  @@index([activo])
  @@index([orden])
}

model PrecioServicio {
  id String @id @default(cuid())

  // Relaciones
  tipoServicioId String
  tipoServicio   TipoServicio @relation(fields: [tipoServicioId], references: [id])
  clienteId      String
  cliente        Cliente      @relation(fields: [clienteId], references: [id])

  // Precio
  precio Float // Precio por unidad

  // Vigencia
  fechaDesde DateTime  @default(now())
  fechaHasta DateTime? // null = vigente actualmente

  // Observaciones
  observaciones String?

  // Auditoría
  createdBy String? // ID del operador que creó el precio

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación con historial
  historial PrecioHistorial[]

  @@index([tipoServicioId])
  @@index([clienteId])
  @@index([fechaDesde])
  @@index([fechaHasta])
}

// ==================== HISTORIAL DE PRECIOS ====================

model PrecioHistorial {
  id String @id @default(cuid())

  // Relación con el precio actual (opcional, null si el precio fue eliminado)
  precioServicioId String?
  precioServicio   PrecioServicio? @relation(fields: [precioServicioId], references: [id])

  // Snapshot del tipo de servicio y cliente (por si se eliminan)
  tipoServicioId     String
  tipoServicioNombre String // Snapshot del nombre
  clienteId          String
  clienteNombre      String // Snapshot del nombre

  // Cambio de precio
  precioAnterior Float? // null si es creación
  precioNuevo    Float // Precio establecido

  // Vigencia
  fechaDesde DateTime // Desde cuándo rige
  fechaHasta DateTime? // Hasta cuándo rigió (null = vigente)

  // Motivo del cambio
  motivo String? // "Ajuste trimestral", "Nuevo contrato", etc.

  // Auditoría
  operadorId     String? // Quién hizo el cambio
  operadorNombre String? // Snapshot del nombre
  tipoCambio     String  @default("CREACION") // CREACION, ACTUALIZACION, ELIMINACION

  createdAt DateTime @default(now())

  @@index([precioServicioId])
  @@index([tipoServicioId])
  @@index([clienteId])
  @@index([fechaDesde])
  @@index([operadorId])
  @@index([tipoCambio])
}

// ==================== PAGOS DE FACTURAS ====================

model PagoFactura {
  id String @id @default(cuid())

  // Factura relacionada
  facturaId String
  factura   Factura @relation(fields: [facturaId], references: [id])

  // Datos del pago
  fecha DateTime @default(now())
  monto Float // Monto pagado

  // Método de pago
  metodoPago String  @default("EFECTIVO") // EFECTIVO, TRANSFERENCIA, CHEQUE, TARJETA
  referencia String? // N° de transferencia, cheque, etc.

  // Información adicional
  banco        String?
  numeroCheque String?
  fechaCheque  DateTime? // Para cheques diferidos

  observaciones String?

  // Operador que registró
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facturaId])
  @@index([fecha])
  @@index([metodoPago])
}

// ==================== TIPO COMPROBANTE ====================

enum TipoComprobante {
  FACTURA_A
  FACTURA_B
  FACTURA_C
  REMITO
  NOTA_CREDITO
  NOTA_DEBITO
}

// ==================== CONDICIÓN IVA ====================

enum CondicionIva {
  RI // Responsable Inscripto
  CF // Consumidor Final
  MT // Monotributista
  EX // Exento
  NC // No Categorizado
}

// ==================== BORRADORES (CAPA 2) ====================
// Almacena datos de formularios en progreso que se auto-salvan
// periódicamente. El operador puede recuperarlos si cierra
// accidentalmente el navegador o pierde conexión.

model Borrador {
  id         String         @id @default(cuid())
  modulo     String // ej: 'pesajeCamiones', 'romaneo', etc.
  operadorId String? // Quien está editando
  datos      String // JSON con los datos del formulario
  estado     EstadoBorrador @default(ACTIVO)

  // Para recuperar el borrador correcto (1 borrador activo por módulo+operador)
  sesionKey String? // Clave única de sesión (módulo + operador)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modulo, sesionKey])
  @@index([modulo])
  @@index([operadorId])
  @@index([estado])
}

enum EstadoBorrador {
  ACTIVO // Borrador en edición
  RECUPERADO // Borrador recuperado por el operador
  DESCARTADO // Borrador descartado manualmente
  EXPIRADO // Borrador que expiró (más de 24hs)
}

// ==================== CUARTOS (CUARTEO) ====================

model Cuarto {
  id           String        @id @default(cuid())
  mediaResId   String // Origin media res
  mediaRes     MediaRes      @relation(fields: [mediaResId], references: [id])
  tipo         TipoCuarto // DELANTERO, TRASERO
  tipoCuartoId String?
  tipoCuarto   C2TipoCuarto? @relation(fields: [tipoCuartoId], references: [id])
  peso         Float
  codigo       String        @unique // Barcode

  // Trazabilidad
  tropaCodigo String?
  garron      Int?
  sigla       SiglaMedia @default(A)

  // Ubicación
  camaraId String?
  camara   Camara? @relation(fields: [camaraId], references: [id])

  // Propietario
  propietarioId String?
  propietario   Cliente? @relation("CuartoPropietario", fields: [propietarioId], references: [id])

  // Estado
  estado EstadoCuarto @default(EN_CAMARA)

  // Registro cuarteo
  registroCuarteoId   String?
  ingresoDespostadaId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cajas CajaEmpaque[]

  @@index([estado])
  @@index([camaraId])
  @@index([propietarioId])
  @@index([tipoCuartoId])
}

enum TipoCuarto {
  DELANTERO
  TRASERO
  ASADO
}

enum EstadoCuarto {
  EN_CAMARA
  EN_DESPOSTADA
  DESPACHADO
}

// ==================== DECOMISOS ====================

model Decomiso {
