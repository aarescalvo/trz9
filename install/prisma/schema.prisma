// ==================== EMPAQUE ====================

model RegistroEmpaque {
  id String @id @default(cuid())

  // Identificación del paquete
  paqueteId String @unique // Código del paquete (EMP-2024-0001)

  // Producto
  producto   String // Nombre del producto
  productoId String? // ID del producto (si existe en catálogo)

  // Cantidad y peso
  pesoKg   Float @default(0) // Peso por unidad
  cantidad Int   @default(1) // Cantidad de unidades

  // Destino
  destino  String? // Cámara o destino final
  camaraId String?
  camara   Camara? @relation(fields: [camaraId], references: [id])

  // Estado
  estado EstadoEmpaque @default(PENDIENTE)

  // Lote de origen (despostada)
  loteId String?
  lote   LoteDespostada? @relation(fields: [loteId], references: [id])

  // Operador
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  // Fecha de despacho
  fechaDespacho DateTime?

  observaciones String?

  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([producto])
  @@index([estado])
  @@index([fecha])
}

enum EstadoEmpaque {
  PENDIENTE
  EMPACADO
  DESPACHADO
  ANULADO
}

// ==================== INGRESO A DESPOSTADA ====================

model IngresoDespostada {
  id String @id @default(cuid())

  // Media de origen
  mediaResId String?

  // Datos de la media
  tropaCodigo String?
  mediaCodigo String? // Código de la media res
  tipoMedia   TipoMedia @default(DELANTERA)

  // Peso
  pesoKg Float @default(0)

  // Origen y destino
  camaraOrigenId  String?
  camaraOrigen    Camara? @relation("IngresoOrigen", fields: [camaraOrigenId], references: [id])
  camaraDestinoId String?
  camaraDestino   Camara? @relation("IngresoDestino", fields: [camaraDestinoId], references: [id])

  // Lote de despostada
  loteId String?
  lote   LoteDespostada? @relation(fields: [loteId], references: [id])

  // Estado
  estado EstadoIngreso @default(PENDIENTE)

  // Operador
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  observaciones String?

  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tropaCodigo])
  @@index([estado])
  @@index([fecha])
}

enum TipoMedia {
  DELANTERA
  TRASERA
  ENTERA
}

enum EstadoIngreso {
  PENDIENTE
  INGRESADO
  EN_PROCESO
  PROCESADO
  DEVUELTO
  ANULADO
}

// ==================== BALANZAS ====================

model Balanza {
  id     String  @id @default(cuid())
  nombre String // Nombre identificatorio
  codigo String? @unique // Código interno

  // Configuración de conexión
  tipoConexion TipoConexionBalanza @default(SERIAL) // SERIAL, TCP, SIMULADA
  puerto       String? // COM1, COM2, etc. para serial
  baudRate     Int                 @default(9600)
  dataBits     Int                 @default(8)
  parity       String?             @default("none") // none, odd, even
  stopBits     Int?                @default(1)

  // Para conexión TCP/IP
  ip        String? // Dirección IP si es TCP
  puertoTcp Int? // Puerto TCP

  // Configuración de protocolo
  protocolo        ProtocoloBalanza @default(GENERICO) // Protocolo de comunicación
  comandoPeso      String? // Comando para solicitar peso
  formatoRespuesta String? // Formato de la respuesta (regex)

  // Configuración de peso
  capacidadMax Float? // Capacidad máxima en kg
  division     Float? @default(0.1) // División mínima
  unidad       String @default("kg") // kg, lb, g

  // Calibración
  fechaCalibracion   DateTime?
  proximaCalibracion DateTime?

  // Estado
  activa      Boolean       @default(true)
  estado      EstadoBalanza @default(DESCONECTADA)
  ultimoError String?

  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  puestos   PuestoTrabajo[]
  terminals Terminal[]

  @@index([activa])
  @@index([estado])
}

enum TipoConexionBalanza {
  SERIAL // Puerto serie (COM)
  TCP // Conexión TCP/IP
  SIMULADA // Modo simulación/demomo
}

enum ProtocoloBalanza {
  GENERICO // Protocolo genérico ASCII
  TOLEDO // Balanzas Toledo
  METTLER // Mettler Toledo
  OHAUS // Ohaus
  DIGI // Digi
  ADAM // Adam Equipment
  CUSTOM // Protocolo personalizado
}

enum EstadoBalanza {
  DESCONECTADA
  CONECTADA
  ERROR
  CALIBRANDO
  LISTA
}

// ==================== PUESTOS DE TRABAJO ====================

model PuestoTrabajo {
  id     String  @id @default(cuid())
  nombre String // "Romaneo 1", "Pesaje Camiones", etc.
  codigo String? @unique // Código interno

  // Ubicación física
  sector    String? // FAENA, ROMANEO, DESPACHO, etc.
  ubicacion String? // Descripción de ubicación

  // Configuración de hardware
  balanzaId String? // Balanza asignada
  balanza   Balanza? @relation(fields: [balanzaId], references: [id])

  // Impresora de rótulos
  impresoraIp     String? // IP de la impresora de rótulos
  impresoraPuerto Int?    @default(9100)
  impresoraModelo String? // Modelo de impresora (Zebra ZT410, etc.)
  rotuloDefaultId String? // Rótulo por defecto para este puesto

  // Impresora de tickets (para pesaje camiones)
  impresoraTicketsIp     String?
  impresoraTicketsPuerto Int?

  // Scanner/Lector de código de barras
  scannerHabilitado Boolean @default(false)
  scannerPuerto     String?

  // Configuración de pantalla
  modoPantalla String? @default("normal") // normal, touchscreen, kiosk

  // Estado
  activo    Boolean @default(true)
  operativo Boolean @default(true)

  // Turno actual
  operadorActualId String? // Operador logueado actualmente

  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo])
  @@index([sector])
}

// ==================== REPORTES SENASA ====================

model ReporteSenasa {
  id String @id @default(cuid())

  // Tipo de reporte
  tipoReporte TipoReporteSenasa

  // Período del reporte
  fechaDesde DateTime
  fechaHasta DateTime
  periodo    String // Descripción del período (ej: "Enero 2024")

