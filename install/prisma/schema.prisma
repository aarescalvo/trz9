// ==================== ORDEN DE CARGA ====================

model OrdenCarga {
  id               String    @id @default(cuid())
  despachoId       String    @unique
  despacho         Despacho  @relation(fields: [despachoId], references: [id])
  numero           Int
  codigo           String
  horaPreparacion  String
  estado           String    @default("PENDIENTE")
  firmaOperario    String?
  firmaChofer      String?
