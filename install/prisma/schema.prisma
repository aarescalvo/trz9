  updatedAt DateTime @updatedAt

  mediasRes MediaRes[]
  decomisos Decomiso[]

  @@index([fecha])
  @@index([garron])
  @@index([estado])
}

enum EstadoRomaneo {
  BORRADOR // Capa 2: Romaneo en progreso, auto-guardado
  PENDIENTE
  CONFIRMADO
  ANULADO
}

// ==================== MEDIAS RESES ====================

model MediaRes {
  id        String  @id @default(cuid())
  romaneoId String
  romaneo   Romaneo @relation(fields: [romaneoId], references: [id])

  lado  LadoMedia // IZQUIERDA o DERECHA
  peso  Float
  sigla SiglaMedia @default(A) // A, T, D

  // Código de barras
  codigo String @unique

  // Estado
  estado EstadoMediaRes @default(EN_CAMARA)

  // Cámara
  camaraId String?
  camara   Camara? @relation(fields: [camaraId], references: [id])

  // Usuario de faena (dueño de la media res)
  usuarioFaenaId String? // ID del cliente usuario de faena
  usuarioFaena   Cliente? @relation(fields: [usuarioFaenaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  despachoItems DespachoItem[]

  // Facturación
  facturado Boolean    @default(false) // Si ya fue facturada
  facturaId String? // ID de la factura donde se facturó
  cuartos   Cuarto[]
  decomisos Decomiso[] @relation("DecomisoMediaRes")

  @@unique([romaneoId, lado, sigla])
  @@index([estado])
  @@index([usuarioFaenaId])
}

enum LadoMedia {
  IZQUIERDA
  DERECHA
}

enum SiglaMedia {
  A // Asado
  T // Trasero
  D // Delantero
}

enum EstadoMediaRes {
  EN_CAMARA
  EN_CUARTEO
  DESPACHADO
}

// ==================== STOCK CÁMARA ====================

model StockMediaRes {
