  ultimoEnvio   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==================== RENDIMIENTO HISTÓRICO ====================

model RendimientoHistorico {
  id               String     @id @default(cuid())
  anio             Int
  mes              Int
  especie          Especie
  tipoAnimal       TipoAnimal
  cantidadAnimales Int        @default(0)
  pesoVivoPromedio Float?
  pesoFrioPromedio Float?
  rindePromedio    Float?
  rindeMinimo      Float?
  rindeMaximo      Float?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([anio, mes, especie, tipoAnimal], name: "rendimientoHistorico_anio_mes_especie_tipo")
  @@index([anio])
  @@index([mes])
  @@index([especie])
}

// ==================== INVENTARIOS ====================

model Inventario {
  id                 String           @id @default(cuid())
  numero             Int
  depositoId         String
  deposito           Deposito         @relation(fields: [depositoId], references: [id])
  fechaInicio        DateTime         @default(now())
  fechaFin           DateTime?
  operadorId         String?
  supervisorId       String?
  estado             EstadoInventario @default(PENDIENTE)
  observaciones      String?
  itemsTotal         Int              @default(0)
  itemsConDiferencia Int              @default(0)
  valorDiferencia    Float?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  detalles DetalleInventario[]

  @@index([depositoId])
  @@index([estado])
}

model DetalleInventario {
  id              String     @id @default(cuid())
  inventarioId    String
  inventario      Inventario @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  insumoId        String
  insumo          Insumo     @relation(fields: [insumoId], references: [id])
  cantidadSistema Float      @default(0)
  cantidadFisica  Float      @default(0)
  diferencia      Float      @default(0)
  costoUnitario   Float?
  costoDiferencia Float?
  estado          String?
  observaciones   String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([inventarioId, insumoId], name: "detalleInventario_insumo_deposito")
  @@index([inventarioId])
}

// ==================== COSTOS DE FAENA ====================

model CostoFaena {
  id          String    @id @default(cuid())
  nombre      String
  descripcion String?
  tipo        String
  monto       Float
  monedaId    String?
  aplicaA     String    @default("TODOS")
  fechaDesde  DateTime  @default(now())
  fechaHasta  DateTime?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  costosAplicados CostoFaenaAplicado[]

  @@index([tipo])
  @@index([activo])
}

model CostoFaenaAplicado {
  id            String     @id @default(cuid())
  listaFaenaId  String
  listaFaena    ListaFaena @relation(fields: [listaFaenaId], references: [id])
  costoFaenaId  String
  costoFaena    CostoFaena @relation(fields: [costoFaenaId], references: [id])
  cantidad      Int        @default(1)
  montoUnitario Float
  montoTotal    Float
  observaciones String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([listaFaenaId])
  @@index([costoFaenaId])
}

model ResumenCostosFaena {
  id             String     @id @default(cuid())
  listaFaenaId   String     @unique
  listaFaena     ListaFaena @relation(fields: [listaFaenaId], references: [id])
  totalAnimales  Int?
  totalKg        Float?
  costoTotal     Float      @default(0)
  costoPorKg     Float?
  costoPorAnimal Float?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// ==================== CENTROS DE COSTO ====================

model CentroCosto {
  id                 String   @id @default(cuid())
  codigo             String   @unique
  nombre             String
  descripcion        String?
  tipo               String
  responsable        String?
  presupuestoMensual Float?
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  presupuestos        PresupuestoCentro[]
  consumosCentro      ConsumoCentro[]
  consumosInsumo      ConsumoInsumo[]
  detallesOrdenCompra DetalleOrdenCompra[]

  balancesInsumos BalanceInsumos[]

  @@index([activo])
}

model ConsumoCentro {
  id            String      @id @default(cuid())
  centroCostoId String
  centroCosto   CentroCosto @relation(fields: [centroCostoId], references: [id])
  fecha         DateTime    @default(now())
  concepto      String
  categoria     String?
  cantidad      Float?
  monto         Float
  observaciones String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([centroCostoId])
  @@index([fecha])
}

model ConsumoInsumo {
  id                String       @id @default(cuid())
  insumoId          String
  insumo            Insumo       @relation(fields: [insumoId], references: [id])
  centroCostoId     String?
  centroCosto       CentroCosto? @relation(fields: [centroCostoId], references: [id])
  cantidad          Float
  costoUnitario     Float?
  costoTotal        Float?
  tropaId           String?
  produccionFecha   DateTime?
  cantidadProducida Float?
  consumoEstandar   Float?
  desviacion        Float?
  observaciones     String?
  fecha             DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([insumoId])
  @@index([centroCostoId])
  @@index([tropaId])
  @@index([fecha])
}

model PresupuestoCentro {
  id            String      @id @default(cuid())
  centroCostoId String
  centroCosto   CentroCosto @relation(fields: [centroCostoId], references: [id])
  anio          Int
  mes           Int
  presupuesto   Float       @default(0)
  ejecutado     Float       @default(0)
  desviacion    Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([centroCostoId, anio, mes])
}

model BalanceInsumos {
  id              String       @id @default(cuid())
  fechaDesde      DateTime
  fechaHasta      DateTime
  centroCostoId   String?
  centroCosto     CentroCosto? @relation(fields: [centroCostoId], references: [id])
  consumoTotal    Float        @default(0)
  kgProducidos    Float        @default(0)
  cabezasFaenadas Int          @default(0)
  costoPorKg      Float?
  costoPorCabeza  Float?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([centroCostoId])
}

// ==================== SUBPRODUCTOS INCOMESTIBLES ====================

model SubproductoIncomestible {
