  operador   Operador? @relation(fields: [operadorId], references: [id])

  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([garron])
  @@index([tipo])
  @@index([fecha])
  @@index([mediaResId])
