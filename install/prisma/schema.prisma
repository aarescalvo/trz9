  garron      Int?

  // Tipo
  tipo TipoGrasa @default(RENDERING)

  // Peso
  pesoTotal Float @default(0)

  // Estado
  enStock Boolean @default(true)

  // Fechas
  fechaFaena DateTime @default(now())

  // Destino
  destino String?

  // Operador
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tropaCodigo])
  @@index([fechaFaena])
  @@index([enStock])
}

enum TipoGrasa {
  RENDERING
  GRASA_DRESSING
  GRASA_COMESTIBLE
}

// ==================== PALLETS Y CAJAS DE EMPAQUE ====================

model Pallet {
  id       String  @id @default(cuid())
  numero   String  @unique
  ssccCode String? @unique

  // Expedición
  expedicionId String?

  // Contenido
  cajas CajaEmpaque[]

  // Estado
  estado  EstadoPallet @default(ARMADO)
  esMixto Boolean      @default(false)

  // Peso total
  pesoTotal     Float @default(0)
  cantidadCajas Int   @default(0)

  // Ubicación
  camaraId String?
  camara   Camara? @relation(fields: [camaraId], references: [id])

  observaciones     String?
  expedicionOrdenId String?

  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado])
  @@index([expedicionId])
  @@index([esMixto])
}

model CajaEmpaque {
  id     String @id @default(cuid())
  numero String @unique

  // Pallet
  palletId String?
  pallet   Pallet? @relation(fields: [palletId], references: [id])

  // Producto (Ciclo I - legado)
  productoId String?
  producto   Producto? @relation(fields: [productoId], references: [id])

  // Producto de Desposte (Ciclo II)
  productoDesposteId String?
  productoDesposte   C2ProductoDesposte? @relation(fields: [productoDesposteId], references: [id])

  // Cuarto de origen
  cuartoId String?
  cuarto   Cuarto? @relation(fields: [cuartoId], references: [id])

  // Lote
  loteId String?
  lote   LoteDespostada? @relation(fields: [loteId], references: [id])

  // Propietario
  propietarioId String?
  propietario   Cliente? @relation("CajaPropietario", fields: [propietarioId], references: [id])

  // Peso
  pesoBruto Float @default(0)
  pesoNeto  Float @default(0)
  tara      Float @default(0)
  piezas    Int   @default(1) // Cantidad de piezas en la caja

  // Trazabilidad
  tropaCodigo String?

  // Fechas de trazabilidad (Ciclo II)
  fechaFaena       DateTime? // Fecha de faena (heredada)
  fechaDesposte    DateTime? // Fecha de desposte
  fechaVencimiento DateTime? // Fecha de vencimiento

  // Estado
  estado EstadoCaja @default(ARMADA)

  // Código de barras
  codigoBarras   String? // Código legado
  barcodeGs1_128 String? // GS1-128 completo (generado)

  // Degradaciones (C2) - excepcional
  degradaciones C2MovimientoDegradacion[] @relation("CajaDegradada")

  // Expediciones (C2)
  expedicionItems C2ExpedicionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([palletId])
  @@index([productoId])
  @@index([productoDesposteId])
  @@index([estado])
  @@index([tropaCodigo])
  @@index([fechaFaena])
}

enum EstadoPallet {
  ARMADO
  EN_CAMARA
  DESPACHADO
}

enum EstadoCaja {
  ARMADA
  EN_PALLET
  EN_CAMARA
  DESPACHADA
}

// ==================== STOCK PRODUCTOS ====================

model StockProducto {
  id String @id @default(cuid())

  // Producto
  productoNombre String
  productoId     String?
  producto       Producto? @relation(fields: [productoId], references: [id])

  // Relación con producto de desposte (C2)
  productoDesposteId String?
  productoDesposte   C2ProductoDesposte? @relation(fields: [productoDesposteId], references: [id])

  // Lote/Tropa
  lote        String?
  tropaCodigo String?

  // Cámara
  camaraId String?
  camara   Camara? @relation(fields: [camaraId], references: [id])

  // Cantidades
  cantidad  Int   @default(0)
  pesoTotal Float @default(0)

  // Tipo y estado
  tipo   String? // CORTE, MENUDENCIA, SUBPRODUCTO
  estado String  @default("DISPONIBLE")

  fechaIngreso DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productoId])
  @@index([camaraId])
  @@index([estado])
  @@index([tropaCodigo])
}

// ==================== TRIBUTOS DE FACTURAS (Retenciones/Percepciones) ====================

model FacturaTributo {
  id        String  @id @default(cuid())
  facturaId String
  factura   Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  // Tipo de tributo (código AFIP)
  tributoId   Int // 1=Nacional, 4=Percep.IIBB, 5=Percep.IVA, 6=Percep.Gan, 7=Otros
  descripcion String // "Percepción IIBB CABA", "Retención Ganancias", etc.

  // Cálculo
  baseImponible Float @default(0)
  alicuota      Float @default(0) // Porcentaje
  importe       Float @default(0) // Monto calculado

  createdAt DateTime @default(now())

  @@index([facturaId])
  @@index([tributoId])
}

// ==================== NOTAS DE CRÉDITO/DÉBITO ====================

model NotaCreditoDebito {
  id              String @id @default(cuid())
  tipo            String // CREDITO, DEBITO
  tipoComprobante Int // 02, 03, 07, 08, 12, 13 (AFIP codes)

  // Referencia a factura original
  facturaId String
  factura   Factura @relation(fields: [facturaId], references: [id])

  // Datos
  numero     Int // Número secuencial
  puntoVenta Int      @default(1)
  fecha      DateTime @default(now())

  // Motivo
  motivo      String // DEVOLUCION, DESCUENTO, ERROR, ANULACION, AJUSTE
  descripcion String?

  // CAE (si aplica)
  cae            String?
  caeVencimiento DateTime?

  // Totales
  subtotal Float @default(0)
  iva      Float @default(0)
  total    Float @default(0)

  // Estado
  estado String @default("EMITIDA") // EMITIDA, ANULADA

  // Operador
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facturaId])
  @@index([tipo])
  @@index([fecha])
  @@index([estado])
}

// ==================== CONFIGURACIÓN AFIP ====================

model ConfiguracionAFIP {
  id String @id @default(cuid())

  // Certificados
  certificadoPath  String? // Ruta al certificado .crt
  clavePrivadaPath String? // Ruta a la clave privada .key

  // Entorno
  entorno String @default("testing") // testing | production

  // CUIT y razón social del emisor
  cuit              String?
  razonSocial       String?
  inicioActividades DateTime?

  // Puntos de venta habilitados
  puntosVenta String? // JSON array: [1, 2, 3]

  // Credenciales WSAA
  wsaaUrl String? // URL del WSAA
  wsfeUrl String? // URL del WSFEv1

  // Último token obtenido (cache)
  tokenWsfe       String?
  signWsfe        String?
  tokenExpiracion DateTime?

  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AlicuotaIVA {
  CERO // 0% - Exento
  DIEZ_CINCO // 10.5% - Carnes frescas
  VEINTIUNO // 21% - Productos elaborados/servicios
  VEINTISIETE // 27% - Servicios especiales
}

// ==================== TARIFAS Y LIQUIDACIONES ====================

model TipoTarifa {
  id          String  @id @default(cuid())
  codigo      String  @unique // FAENA_BOV, FAENA_EQU, ESTACIONAMIENTO, FLETE, etc.
  descripcion String
  unidad      String  @default("POR_KG") // POR_KG, POR_CABEZA, FIJO, POR_KG_POR_DIA
  activo      Boolean @default(true)
  orden       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  historico HistoricoTarifa[]

  @@index([activo])
  @@index([orden])
}

model HistoricoTarifa {
  id           String     @id @default(cuid())
  tipoTarifaId String
  tipoTarifa   TipoTarifa @relation(fields: [tipoTarifaId], references: [id])

  // Segmentación (puede ser global, por especie, por usuario/cliente)
  clienteId String? // null = tarifa general; con valor = tarifa especial del cliente
  especie   String? // BOVINO, EQUINO, etc.; null = todas
  categoria String? // NOVILLO, VACA, etc.; null = todas

  // Precio y vigencia
  valor         Float // precio en pesos
  moneda        String    @default("ARS")
  vigenciaDesde DateTime // desde cuándo aplica
  vigenciaHasta DateTime? // null = vigente actualmente

  // Auditoría
  operadorId String? // quién lo cargó
  motivo     String? // "Actualización por inflación", "Acuerdo con cliente X", etc.

  createdAt DateTime @default(now())

  cliente  Cliente?  @relation(fields: [clienteId], references: [id])
  operador Operador? @relation(fields: [operadorId], references: [id])

  @@index([tipoTarifaId, vigenciaDesde])
  @@index([clienteId, tipoTarifaId])
  @@index([especie])
  @@index([vigenciaHasta])
}

model LiquidacionFaena {
  id     String @id @default(cuid())
  numero Int    @unique

  // Vínculos con el ciclo productivo
  tropaId   String  @unique
  tropa     Tropa   @relation(fields: [tropaId], references: [id])
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  // Datos de la faena (solo lectura desde romaneo)
  fechaFaena  DateTime
  dteSenasa   String?
  certFaena   String?
  cantCabezas Int
  kgRomaneo   Float // SOLO LECTURA — tomado del romaneo cerrado

  // Tarifa aplicada (congelada)
  tarifaFaenaId    String? // referencia al HistoricoTarifa usado
  tarifaFaenaValor Float // valor copiado (no depender del histórico para recalcular)

  // Conceptos adicionales
  items LiquidacionItem[]

  // Totales calculados
  subtotalNeto     Float @default(0)
  totalIVA         Float @default(0)
  totalRetenciones Float @default(0)
  totalFinal       Float @default(0)

  // Estado
  estado String @default("BORRADOR") // BORRADOR, EMITIDA, ANULADA

  // Comprobante generado
  facturaId String?  @unique
  factura   Factura? @relation(fields: [facturaId], references: [id])

  // Supervisor que aprobó edición
  supervisorId String?
  supervisor   Operador? @relation("LiquidacionSupervisor", fields: [supervisorId], references: [id])

  operadorId String?
  operador   Operador? @relation("LiquidacionOperador", fields: [operadorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tropaId])
  @@index([clienteId])
  @@index([estado])
  @@index([fechaFaena])
}

model LiquidacionItem {
  id            String           @id @default(cuid())
  liquidacionId String
  liquidacion   LiquidacionFaena @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)

  tipoTarifaId String?
  descripcion  String
  unidad       String  @default("POR_KG") // POR_KG, POR_CABEZA, FIJO
  cantidad     Float   @default(0) // kg, cabezas, o 1 si es fijo
  tarifaValor  Float   @default(0) // valor congelado
  subtotal     Float   @default(0)
  alicuotaIVA  Float   @default(21) // 0, 10.5, 21
  importeIVA   Float   @default(0)

  esDescuento Boolean @default(false) // para cueros/menudencias cedidos como pago parcial

  createdAt DateTime @default(now())

  @@index([liquidacionId])
  @@index([tipoTarifaId])
}

// ====================================================================================
// CICLO II - DESPOSTE Y LOGÍSTICA
// Módulo de transformación de Medias Res → Cortes/Cajas con trazabilidad completa
// ====================================================================================

// ==================== C2 - RUBROS (Agrupadores de productos de desposte) ====================

model C2Rubro {
  id          String  @id @default(cuid())
  nombre      String  @unique // Ej: Cortes Traseros, Cortes Delanteros, Menudencias, Elaborados
  descripcion String?
  orden       Int     @default(0) // Orden de aparición en UI
  activo      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productos C2ProductoDesposte[]

  @@index([activo])
  @@index([orden])
}

// ==================== C2 - TIPOS DE CUARTO (Configurable, normalmente 3: Delantero, Trasero, Asado) ====================

model C2TipoCuarto {
  id          String  @id @default(cuid())
  nombre      String  @unique // Ej: Delantero, Trasero, Asado
  codigo      String  @unique // Ej: DEL, TRA, ASA (para rótulos/códigos)
  descripcion String?
  orden       Int     @default(0) // Orden de aparición en pantalla de cuarteo
  activo      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cuartos Cuarto[]

  @@index([activo])
  @@index([orden])
}

// ==================== C2 - PRODUCTOS DE DESPOSTE (Cortes, con código individual y GTIN) ====================

model C2ProductoDesposte {
  id      String  @id @default(cuid())
  rubroId String // FK a C2Rubro
  rubro   C2Rubro @relation(fields: [rubroId], references: [id])

  nombre String // Ej: Lomo, Bife de Chorizo, Nalga
  codigo String @unique // Código interno individual del producto

  // Código GS1 / GTIN para etiquetas GS1-128
  gtin String? // GTIN del producto (14 dígitos)

  // Especie
  especie Especie @default(BOVINO)

  // Clasificación del cuarto de origen (de qué cuarto sale este corte)
  tipoCuartoOrigen String? // DELANTERO, TRASERO, ASADO - de qué cuarto proviene normalmente

  // Datos de conservación
  diasVencimiento Int? // Días de vida útil
  tempMin         Float? // Temperatura mínima de conservación
  tempMax         Float? // Temperatura máxima de conservación

  // Tara del envase
  pesoTaraCaja Float? // Peso de la caja/bolsa (tara)

  // Precios (para facturación de cortes)
  precioKg Float? // Precio por KG

  // Reportes
  apareceRendimiento Boolean @default(true) // Aparece en reporte de rinde
  apareceStock       Boolean @default(true) // Aparece en stock

  activo        Boolean @default(true)
  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bomItems           C2BOM[]
  cajas              CajaEmpaque[]
  stockProductos     StockProducto[]
  degradacionesHacia C2MovimientoDegradacion[] @relation("ProductoDegradadoHacia")

  @@index([rubroId])
  @@index([especie])
  @@index([activo])
  @@index([tipoCuartoOrigen])
}

// ==================== C2 - BOM (Bill of Materials - Insumos por producto) ====================
// Define qué insumos se consumen al producir una caja de cada producto
// Ej: Caja de Lomo → 1 bolsa x lomo + 1 caja + 2 fajas + 1 lámina

model C2BOM {
  id                 String             @id @default(cuid())
  productoDesposteId String // FK al producto de desposte
  productoDesposte   C2ProductoDesposte @relation(fields: [productoDesposteId], references: [id], onDelete: Cascade)

  insumoId String // FK al insumo
  insumo   Insumo @relation(fields: [insumoId], references: [id])

  cantidadPorCaja Float @default(1) // Cantidad de este insumo por cada caja producida

  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productoDesposteId, insumoId])
  @@index([productoDesposteId])
  @@index([insumoId])
}

// ==================== C2 - MOVIMIENTOS DE DEGRADACIÓN (Excepcional) ====================
// Registro de cuando un corte se degrada (golpeado, trimming, decomiso parcial)

model C2MovimientoDegradacion {
  id String @id @default(cuid())

  // Caja original
  cajaIdOriginal String // ID de la caja degradada
  cajaOriginal   CajaEmpaque @relation("CajaDegradada", fields: [cajaIdOriginal], references: [id])

  // Tipo de degradación
  tipo TipoDegradacion @default(TRIMMING)

  // Pesos
  pesoDegradado       Float // Peso del corte degradado
  pesoAprovechamiento Float? // Peso que se puede reutilizar (si aplica)
  pesoDescarte        Float? // Peso que se descarta

  // Nuevo producto (si el aprovechamiento se reasigna)
  nuevoProductoId String? // FK a C2ProductoDesposte (ej: Lomo degradado → Carne para milanesa)
  nuevoProducto   C2ProductoDesposte? @relation("ProductoDegradadoHacia", fields: [nuevoProductoId], references: [id])

  // Motivo
  motivo String // Ej: "Golpeado", "Contaminación superficial", "Vencimiento próximo"

  // Operador
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  observaciones String?
  fecha         DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cajaIdOriginal])
  @@index([tipo])
  @@index([fecha])
}

enum TipoDegradacion {
  TRIMMING // Recorte de grasa/limpieza
  GOLPEADO // Corte golpeado
  DECOMISO_PARCIAL // Decomiso parcial
  APROVECHAMIENTO // Reasignación a producto de menor valor
}

// ==================== C2 - SUBPRODUCTOS PESAJE (Hueso, Grasa, Incomestible) ====================

model C2SubproductoPesaje {
  id String @id @default(cuid())

  // Tipo de subproducto
  tipo TipoSubproducto @default(HUESO)

  // Tropa de origen
  tropaCodigo String?

  // Peso
  pesoKg Float @default(0)

  // Destino
  destino String? // Ej: "Rendering", "Venta directa"

  // Operador
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  observaciones String?
  fecha         DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo])
  @@index([tropaCodigo])
  @@index([fecha])
}

enum TipoSubproducto {
  HUESO
  GRASA
  INCOMESTIBLE
  RECORTES
  OTRO
}

// ==================== C2 - EXPEDICIÓN (Órdenes de despacho de cajas) ====================

model C2ExpedicionOrden {
  id     String @id @default(cuid())
  numero Int    @unique // Número correlativo

  // Cliente
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  // Datos de transporte
  transporteNombre String?
  patenteCamion    String?
  choferNombre     String?
  choferDni        String?

  // Documentos
  nroRemito String?

  // Fechas
  fechaDespacho DateTime?
  fecha         DateTime  @default(now())

  // Estado
  estado EstadoExpedicion @default(PENDIENTE)

  // Totales
  cantidadCajas Int   @default(0)
  pesoTotal     Float @default(0)

  // Operador
  operadorId String?
  operador   Operador? @relation(fields: [operadorId], references: [id])

  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items C2ExpedicionItem[]

  @@index([clienteId])
  @@index([estado])
  @@index([fecha])
}

model C2ExpedicionItem {
  id      String            @id @default(cuid())
  ordenId String
  orden   C2ExpedicionOrden @relation(fields: [ordenId], references: [id], onDelete: Cascade)

  // Caja despachada
  cajaId String
  caja   CajaEmpaque @relation(fields: [cajaId], references: [id])

  // Pallet (si despacha por pallet)
  palletId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ordenId])
  @@index([cajaId])
  @@index([palletId])
}

enum EstadoExpedicion {
  PENDIENTE
  EN_PREPARACION
  DESPACHADO
  ANULADO
}

// ==================== PREFERENCIAS UI POR USUARIO ====================

model PreferenciasUI {
